---
export const prerender = false;

import NoteList from '~/components/NoteList.astro';
import NoteLayout from '~/layouts/NoteLayout.astro';
import { type SearchResult, searchIndex } from '~/utils/search';

const query = Astro.url.searchParams.get('q')?.trim() || '';
let searchResults: SearchResult[] = [];
let searchError = '';

if (query.length >= 2) {
  try {
    searchResults = await searchIndex(Astro.locals.runtime.env.SEARCH_DB, {
      query,
      limit: 50,
      type: 'note',
    });
  } catch (error) {
    console.error('Search error:', error);
    searchError = `An error occurred while searching for "${query}". Please try again.`;
  }
}

const formattedResults = searchResults.map((result) => ({
  slug: result.url.replace('/notes/', ''),
  title: result.title,
  date: result.date ? new Date(result.date) : undefined,
  tags: result.tags ? result.tags.split(' ').filter(Boolean) : undefined,
  emoji: result.emoji || undefined,
}));
---

<NoteLayout title="Search Notes" subtitle="Search through all code notes" slug="search">
  {
    query ? (
      <div class="search-results">
        <p class="search-summary">
          {searchResults.length > 0 ? (
            <>
              Found <strong>{searchResults.length}</strong> result{searchResults.length !== 1 ? 's' : ''} for "{query}"
            </>
          ) : searchError ? (
            <span class="error">{searchError}</span>
          ) : (
            <>No results found for "{query}"</>
          )}
        </p>

        {searchResults.length > 0 ? <NoteList searchResults={formattedResults} /> : null}
      </div>
    ) : (
      <p class="search-prompt">Enter a search term to find notes.</p>
    )
  }

  <p class="all-site-search">
    Searching everything? Try the <a href={`/search${query ? `?q=${encodeURIComponent(query)}` : ''}`}>site-wide search</a>.
  </p>

  <div class="back-link">
    <a href="/notes">&larr; Back to all notes</a>
  </div>
</NoteLayout>

<style>
  .search-results {
    margin-block-end: var(--space-l);
  }

  .search-summary {
    margin-block-end: var(--space-m);
    opacity: 0.8;
  }

  .search-summary strong {
    color: var(--colour-accent);
  }

  .error {
    color: var(--colour-error, #ef4444);
  }

  .search-prompt {
    opacity: 0.7;
    margin-block-end: var(--space-l);
  }

  .all-site-search {
    font-size: var(--step--1);
    opacity: 0.8;
  }

  .back-link {
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-m);
    border-block-start: 1px solid var(--colour-border);
  }
</style>
