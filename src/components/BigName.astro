---
import { banner } from '~/utils/ascii/figlet';

type Props = {
  text?: string;
  class?: string;
};

const { text = 'ZANDER', class: className } = Astro.props;

const lines = banner(text, { font: 'ANSI Shadow' });
---

<div class:list={['zm-bigName', className]}>
  <pre aria-hidden="true">{lines.join('\n')}</pre>
  <span class="visually-hidden">{text}</span>
</div>

<style>
  .zm-bigName {
    color: var(--color-text-bright);
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  pre {
    font-family: var(--font-display);
    font-size: clamp(0.4rem, 2vw, 1.1rem);
    line-height: 1.05;
    white-space: pre;
    user-select: none;
  }
</style>
