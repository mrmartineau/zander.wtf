---
const { title, subtitle, class: className } = Astro.props;
---

<div class:list={['zm-block', className]}>
  <header>
    <h3 class="zm-block-title">{title}</h3>
    <span class="zm-block-deco" aria-hidden="true">▚▚▚</span>
  </header>

  <div class="zm-block-body">
    {subtitle ? <p class="zm-block-subtitle">{subtitle}</p> : null}
    <slot />
  </div>
</div>

<style>
  .zm-block {
    --block-bg: var(--color-surface);
    --block-padding: var(--space-s-m);
    color: var(--color-text);
    background-color: var(--block-bg);
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-hard);

    a {
      --colour: var(--color-text-bright);
      --colour-decoration: transparent;
    }
  }

  /* Window title bar */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-2xs) var(--block-padding);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .zm-block-title {
    font-family: var(--font-display);
    font-size: var(--step-0);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-bright);
  }

  .zm-block-deco {
    font-family: var(--font-display);
    color: var(--color-faint);
    user-select: none;
  }

  .zm-block-body {
    padding: var(--block-padding);
  }

  .zm-block-subtitle {
    font-style: italic;
    color: var(--color-muted);
    margin-block-end: var(--space-s);
  }
</style>
