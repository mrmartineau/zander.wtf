---
import { ABOUT_ME, SHOW_STATUS } from 'src/consts';
---

{
  SHOW_STATUS ? (
    <div id="status-banner" hidden>
      <a href={ABOUT_ME.email}>
        <div>Available for work from mid-July 2026.<br /> Hire me before someone else does.</div>
        <span>
          Get in touch <i class="ph-duotone ph-paper-plane-right" />
        </span>
      </a>
      <button
        type="button"
        aria-label="Hide this banner permanently"
        title="Hide this banner permanently"
      >
        <i class="ph-fill ph-x-circle" />
      </button>
    </div>
  ) : null
}

<script>
  const banner = document.getElementById('status-banner');
  if (banner) {
    if (localStorage.getItem('zm:hide-status') !== 'true') {
      banner.hidden = false;
    }
    banner.querySelector('button')?.addEventListener('click', () => {
      localStorage.setItem('zm:hide-status', 'true');
      banner.hidden = true;
    });
  }
</script>

<style>
  #status-banner {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    width: max-content;
  }

  #status-banner[hidden] {
    display: none;
  }

  a {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    justify-items: center;
    gap: var(--space-2xs);
    background-color: oklch(from var(--colour-accent) l c h / 80%);
    border-radius: 1rem;
    padding: var(--space-xs);
    font-size: var(--step--1);
    color: var(--bg);
    text-align: center;
    width: max-content;
    font-variation-settings:
      'wght' 400,
      'wdth' 100,
      'ital' 0;
    transition: all 100ms ease-in-out;
    line-height: 1.2;
    backdrop-filter: blur(4px);
  }

  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    background-color: oklch(from var(--colour-accent) l c h / 80%);
    color: var(--bg);
    font-size: var(--step--1);
    backdrop-filter: blur(4px);
    transition: all 100ms ease-in-out;
  }

  button:hover {
    scale: 1.1;
  }

  button i {
    font-size: var(--step-0);
  }

  @media screen and (min-width: 550px) {
    a {
      flex-direction: row;
      border-radius: 999px;
      gap: var(--space-s);
      padding: var(--space-2xs) var(--space-m);
    }
  }

  span {
    transition: all 100ms ease-in-out;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  a:hover span {
    font-variation-settings:
      'wght' 700,
      'wdth' 125,
      'ital' 0;
    scale: 1.05;
  }
</style>
