---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const promoted = allProjects
  .filter((project) => project.data?.promote)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
console.log(`🚀 ~ promoted:`, promoted);
---

<div class="zm-promoted">
  <div class="zm-promoted-grid">
    {
      promoted.map((item) => {

        const { title, subtitle, link, repo, image, bgColour, fgColour } = item.data;
        // Prefer the live link, fall back to the repo, otherwise don't link.
        const href = link || repo;
        // Only set the vars that exist — `--card-fg: undefined` would
        // override the CSS fallback with an invalid value
        const cardStyle = [
          bgColour ? `--card-bg: ${bgColour};` : '',
          fgColour ? `--card-fg: ${fgColour};` : '',
        ].join(' ');
        return (
          <div
            class="zm-promoted-card"
            style={cardStyle}
          >
            {image ? (
              <div class="zm-promoted-image">
                <img src={image} alt={`${title} preview`} />
              </div>
            ) : null}
            <div class="zm-promoted-body">
              <h3 class="zm-promoted-title">{title}</h3>
              <p class="zm-promoted-description">{subtitle}</p>
              <a href={href} class="zm-promoted-link" target="_blank" rel="noopener noreferrer">
                {href}
              </a>
            </div>
          </div>
        );
      })
    }
  </div>

  <div class="text-center">
    <a href="/projects" class="button" transition:persist>
      View all projects
    </a>
  </div>
</div>

<style>
  .zm-promoted {
    margin-block: var(--space-3xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .zm-promoted-grid {
    --grid-count: 1;
    display: grid;
    grid-template-columns: repeat(var(--grid-count), 1fr);
    gap: var(--space-l);

    @media screen and (min-width: 550px) {
      --grid-count: 2;
    }
    @media screen and (min-width: 1350px) {
      --grid-count: 4;
    }
  }

  .zm-promoted-card {
    /* Card backgrounds from frontmatter are dark in both colour schemes,
       so the fallback foreground is a fixed light colour */
    --card-bg: var(--bg-block);
    --card-fg: oklch(95% 0.01 90);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: var(--border-width) solid var(--color-border);
    box-shadow: var(--shadow-hard);
    background-color: var(--card-bg);
    color: var(--card-fg);
    text-decoration: none;
    transition: transform 150ms ease-in-out;
  }

  a.zm-promoted-card {
    --colour-decoration: transparent;
  }

  a.zm-promoted-card:hover {
    transform: translateY(-4px);
  }

  .zm-promoted-image {
    aspect-ratio: 16 / 9;
    background-color: color-mix(in srgb, var(--card-fg) 15%, var(--card-bg));

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .zm-promoted-body {
    padding: var(--space-m);
  }

  .zm-promoted-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--card-fg);
  }

  /* Explicit colour — the global p/a rules would otherwise override
     the per-card foreground from the content frontmatter */
  .zm-promoted-description {
    margin-block-start: var(--space-2xs);
    font-size: var(--step--2);
    color: var(--card-fg);
    opacity: 0.8;
  }

  .zm-promoted-link {
    margin-block-start: var(--space-2xs);
    font-family: var(--font-code);
    font-size: var(--step--2);
    color: var(--card-fg);
    opacity: 0.8;
    display: inline-block;

    &:hover {
      opacity: 1;
    }
  }
</style>
