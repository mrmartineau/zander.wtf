---
import { SITE_NAV_ITEMS } from '../consts';
import BigName from './BigName.astro';

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
---

<header>
  <BigName />
  <nav>
    <a href="/" class:list={[{ active: pathname === '/' }]}>Home</a>
    {
      SITE_NAV_ITEMS.map((item) => {
        const itemPath = item.url.slice(1);
        const isActive = currentPath.startsWith(itemPath);
        return (
          <a href={item.url} class:list={[{ active: isActive }]}>
            {item.text}
          </a>
        );
      })
    }
    <a
      href="/search"
      class:list={['search-link', { active: currentPath.startsWith('search') }]}
      aria-label="Search"
      title="Search (press / anywhere)"
    >
      <i class="ph-duotone ph-magnifying-glass" aria-hidden="true"></i>
      <kbd aria-hidden="true">/</kbd>
    </a>
  </nav>
</header>

<style>
  header {
    margin-bottom: 7vh;
    margin-bottom: min(10vw, 180px);
    color: var(--colour-text-bright);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex-wrap: wrap;
    margin-top: 2vh;
    margin-top: 2dvh;
    row-gap: 1vh;
  }
  a {
    position: relative;
    font-variation-settings:
      'wght' 800,
      'wdth' 125,
      'ital' 0;
    font-size: var(--step--1);
    font-family: var(--font-headings);
    text-transform: uppercase;
    padding: 0 0.5ex;
    letter-spacing: 0.1em;
    leading-trim: both;
    text-edge: cap alphabetic;
    text-decoration: none;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);

    &:hover,
    &.active {
      color: var(--colour-accent);
    }

    &.active::before {
      opacity: 1;
    }
  }

  @media (min-width: 35em) {
    a {
      font-size: var(--step-1);
    }
  }

  .search-link kbd {
    display: none;
  }

  /* Keyboard hint only makes sense where a keyboard is likely */
  @media (min-width: 35em) and (hover: hover) {
    .search-link kbd {
      font-family: var(--font-mono);
      font-size: 0.45em;
      font-variation-settings: normal;
      line-height: 1;
      padding: 0.25em 0.4em 0.25em 0.5em;
      border: 1px solid currentColor;
      border-radius: 0.3em;
      opacity: 0.4;
      aspect-ratio: 1;
      display: inline-flex;
      align-items: center;
      text-align: center;
    }
  }
</style>

<script>
  function isFormField(element: EventTarget | null) {
    if (!(element instanceof HTMLElement)) {
      return false;
    }

    const name = element.nodeName.toLowerCase();
    const type = (element.getAttribute('type') || '').toLowerCase();
    return (
      name === 'select' ||
      name === 'textarea' ||
      (name === 'input' && type !== 'submit' && type !== 'reset') ||
      element.isContentEditable
    );
  }

  // Site-wide "/" shortcut: focus the search input if the page has one,
  // otherwise go to the search page.
  document.addEventListener('keydown', (event) => {
    if (
      event.key !== '/' ||
      event.metaKey ||
      event.ctrlKey ||
      event.altKey ||
      event.isComposing
    ) {
      return;
    }
    if (isFormField(event.target)) {
      return;
    }

    event.preventDefault();
    const input = document.querySelector<HTMLInputElement>('.search-input');
    if (input) {
      input.focus();
    } else {
      window.location.assign('/search');
    }
  });
</script>
