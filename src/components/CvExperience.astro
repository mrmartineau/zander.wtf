---
import { CV_EXPERIENCE } from '../data/cv';

function formatDate(date: string): string {
  if (date === 'present') return 'Present';
  const [year, month] = date.split('-');
  if (!month) return year;
  const d = new Date(Number(year), Number(month) - 1);
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
}
---

<div class="cv-experience">
  {
    CV_EXPERIENCE.map((role) => (
      <div class="cv-role">
        <div class="cv-role-header">
          <div class="cv-role-identity">
            <div class="cv-company">
              {role.url ? (
                <a href={role.url} target="_blank" rel="noopener noreferrer">
                  {role.company}
                </a>
              ) : (
                role.company
              )}
              •
              <span class="cv-industry">{role.industry}</span>
            </div>
            <p class="cv-title">{role.title}</p>
          </div>
          <div class="cv-role-meta">
            <span class="cv-dates">
              {formatDate(role.startDate)}–{formatDate(role.endDate)}
            </span>
            •
            <span class="cv-type">{role.type}</span>
          </div>
        </div>
        <div class="cv-description">
          {role.description.split('\n\n').map((para) => (
            <p>{para}</p>
          ))}
        </div>
        {role.tech && role.tech.length > 0 && (
          <p class="cv-tech">
            <span class="cv-tech-label">Stack:</span>{' '}
            {role.tech.join(', ')}
          </p>
        )}
      </div>
    ))
  }
</div>

<style>
  .cv-experience {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .cv-role {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cv-role-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .cv-role-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: var(--step--2);
    color: var(--color-text-muted, currentColor);
    opacity: 0.6;
    font-family: var(--font-mono);
  }

  .cv-type {
    text-transform: capitalize;
  }

  .cv-company {
    font-size: var(--step-0);
    margin: 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .cv-title {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1ch;
  }

  .cv-description {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .cv-description p {
    margin: 0;
  }

  .cv-tech {
    font-size: var(--step--1);
    margin: 0;
    opacity: 0.75;
  }

  .cv-tech-label {
    font-weight: 600;
  }
</style>
