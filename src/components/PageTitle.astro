---
const { class: className } = Astro.props;
---

<h1 class={className}><span aria-hidden="true">&gt; </span><slot /></h1>

<style>
  h1 {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    line-height: 1.15;
    text-wrap: balance;
    color: var(--color-text-bright);

    span {
      color: var(--color-accent);
      user-select: none;
    }
  }
</style>
